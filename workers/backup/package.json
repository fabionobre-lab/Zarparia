{
	"name": "zarparia-backup",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "wrangler dev --test-scheduled",
		"deploy": "wrangler deploy",
		"cf-typegen": "wrangler types",
		"check": "tsc --noEmit",
		"db:migrate:local": "wrangler d1 migrations apply trips --local",
